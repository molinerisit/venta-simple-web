DATABASE_URL=postgresql://postgres.[ref]:[pass]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
SECRET_KEY=cambia_esto_por_64_chars_random_usa_python_secrets_token_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
FRONTEND_URL=http://localhost:3000

# Mercado Pago — suscripciones recurrentes (preapproval)
MP_ACCESS_TOKEN=APP_USR-...tu-access-token-de-produccion...
WEBHOOK_PUBLIC_URL=https://tu-backend.vercel.app

# Secreto webhook app principal (suscripciones) — Panel MP → app VentaSimple → Webhooks
MP_WEBHOOK_SECRET=
# Secreto webhook app clientes (QR/Point) — Panel MP → app VentaSimpleClientes → Webhooks
MP_QR_WEBHOOK_SECRET=

# Mercado Pago — OAuth de negocios clientes (cobros / QR / Point)
MP_CLIENT_ID=
MP_CLIENT_SECRET=
MP_REDIRECT_URI=https://api.ventasimple.cloud/mercadopago/oauth/callback

# Email (Resend) — https://resend.com/api-keys
# IMPORTANTE: FROM_EMAIL debe usar un dominio verificado en Resend.
# "onboarding@resend.dev" solo funciona para enviar al email de tu cuenta Resend.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=VentaSimple <noreply@tudominio.com>

# Cuenta interna de soporte — soporte@ventasimple.cloud
# Mínimo 16 caracteres, usa un generador de contraseñas seguro.
# Si no se define, la cuenta NO se crea (falla silenciosa).
SUPPORT_PASSWORD=cambia_esto_por_clave_segura_16chars_minimo
